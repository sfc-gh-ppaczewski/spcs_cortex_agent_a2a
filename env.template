# Snowflake Connection
# SNOWFLAKE_ACCOUNT_LOCATOR: Used for JWT auth (e.g., ABC12345)
# SNOWFLAKE_ACCOUNT: Used for API URL - org-account format with hyphens (e.g., MYORG-MYACCOUNT)
SNOWFLAKE_ACCOUNT_LOCATOR=your_account_locator
SNOWFLAKE_ACCOUNT=your_org-your_account
SNOWFLAKE_USER=your_username
PRIVATE_KEY_PATH=rsa_key.p8

# Cortex Agent Object Details
# Specify the fully qualified path to your Cortex Agent: DATABASE.SCHEMA.AGENT_NAME
AGENT_DATABASE=YOUR_DATABASE
AGENT_SCHEMA=YOUR_SCHEMA
AGENT_NAME=YOUR_AGENT_NAME

# Optional: Customize the A2A agent description
AGENT_DESCRIPTION=A Snowflake Cortex Agent exposed via the A2A protocol.
AGENT_URL=http://localhost:8000
